---Before analysis, we inspect the first few rows to understand the data structure.---
USE shopping_trends_updated;
SELECT * FROM shopping_trends LIMIT 5;


---We verify if there are missing values across key analytical dimensions.---
SELECT 
    SUM(CASE WHEN `Age` IS NULL THEN 1 ELSE 0 END) AS Age_Null,
    SUM(CASE WHEN `Gender` IS NULL THEN 1 ELSE 0 END) AS Gender_Null,
    SUM(CASE WHEN `Item Purchased` IS NULL THEN 1 ELSE 0 END) AS Item_Purchased_Null,
    SUM(CASE WHEN `Category` IS NULL THEN 1 ELSE 0 END) AS Category_Null,
    SUM(CASE WHEN `Purchase Amount (USD)` IS NULL THEN 1 ELSE 0 END) AS Purchase_Amount_Null,
    SUM(CASE WHEN `Location` IS NULL THEN 1 ELSE 0 END) AS Location_Null,
    SUM(CASE WHEN `Review Rating` IS NULL THEN 1 ELSE 0 END) AS Review_Rating_Null,
    SUM(CASE WHEN `Subscription Status` IS NULL THEN 1 ELSE 0 END) AS Subscription_Status_Null,
    SUM(CASE WHEN `Previous Purchases` IS NULL THEN 1 ELSE 0 END) AS Previous_Purchases_Null,
    SUM(CASE WHEN `Frequency of Purchases` IS NULL THEN 1 ELSE 0 END) AS Frequency_Null
FROM shopping_trends;


---Ensuring data uniqueness by checking for duplicate records across all fields.---
WITH DuplicateCheck AS (
    SELECT 
        *,
        ROW_NUMBER() OVER(PARTITION BY 
            `Customer ID`, `Age`, `Gender`, `Item Purchased`, `Category`, 
            `Purchase Amount (USD)`, `Location`, `Size`, `Color`, `Season`, 
            `Review Rating`, `Subscription Status`, `Shipping Type`, 
            `Discount Applied`, `Promo Code Used`, `Previous Purchases`, 
            `Payment Method`, `Frequency of Purchases` 
        ORDER BY `Customer ID`) AS row_num
    FROM shopping_trends
)
SELECT * FROM DuplicateCheck 
WHERE row_num > 1;


---Segmenting users into specific age brackets to understand the primary consumer base.---
WITH AgeSegmentation AS (
    SELECT 
        CASE 
            WHEN `Age` < 20 THEN 'Under 20'
            WHEN `Age` BETWEEN 20 AND 30 THEN '20-30'
            WHEN `Age` BETWEEN 31 AND 40 THEN '31-40'
            WHEN `Age` BETWEEN 41 AND 50 THEN '41-50'
            WHEN `Age` BETWEEN 51 AND 60 THEN '51-60'
            ELSE '60+' 
        END AS Age_Group
    FROM shopping_trends
)
SELECT 
    Age_Group,
    COUNT(*) AS User_Count,
    CONCAT(ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2), '%') AS Percentage_Of_Total
FROM AgeSegmentation
GROUP BY Age_Group
ORDER BY MIN(Age_Group);


---Calculating the gender ratio and the average spending power of each group.---
SELECT 
    `Gender`, 
    COUNT(*) AS Total_Users,
    CONCAT(ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2), '%') AS Gender_Ratio,
    ROUND(AVG(`Purchase Amount (USD)`), 2) AS Avg_Spending
FROM shopping_trends
GROUP BY `Gender`;


---Identifying which product categories drive the most revenue.---
SELECT 
    `Category`, 
    SUM(`Purchase Amount (USD)`) AS Total_Revenue,
    COUNT(*) AS Units_Sold,
    RANK() OVER(ORDER BY SUM(`Purchase Amount (USD)`) DESC) AS Revenue_Rank,
    CONCAT(ROUND(SUM(`Purchase Amount (USD)`) * 100.0 / SUM(SUM(`Purchase Amount (USD)`)) OVER(), 2), '%') AS Revenue_Contribution
FROM shopping_trends
GROUP BY `Category`
ORDER BY Total_Revenue DESC;


---Analyzing consumer color choices to inform inventory and visual marketing.---
SELECT 
    `Color`, 
    COUNT(*) AS Quantity_Sold,
    SUM(`Purchase Amount (USD)`) AS Revenue,
    DENSE_RANK() OVER(ORDER BY COUNT(*) DESC) AS Popularity_Rank
FROM shopping_trends
GROUP BY `Color`
ORDER BY Quantity_Sold DESC;


---Analyzing how seasonality affects transaction volume and ticket size.---
SELECT 
    `Season`, 
    SUM(`Purchase Amount (USD)`) AS Seasonal_Revenue,
    COUNT(*) AS Transaction_Count,
    ROUND(AVG(`Purchase Amount (USD)`), 2) AS Avg_Transaction_Value,
    ROUND(AVG(`Purchase Amount (USD)`) - AVG(AVG(`Purchase Amount (USD)`)) OVER(), 2) AS Diff_From_Yearly_Avg
FROM shopping_trends
GROUP BY `Season`
ORDER BY Seasonal_Revenue DESC;


---Understanding the logistics and payment methods preferred by users.---
SELECT 
    `Payment Method`, 
    COUNT(*) AS Usage_Count,
    CONCAT(ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2), '%') AS Share_Pct
FROM shopping_trends
GROUP BY `Payment Method`
ORDER BY Usage_Count DESC;

-- Shipping Type Preference
SELECT 
    `Shipping Type`, 
    COUNT(*) AS Count,
    ROUND(AVG(`Purchase Amount (USD)`), 2) AS Avg_Spend,
    CONCAT(ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2), '%') AS Share_Pct
FROM shopping_trends
GROUP BY `Shipping Type`
ORDER BY Count DESC;


---Analyzing the relationship between discount usage and purchase value.---
SELECT 
    `Discount Applied`, 
    COUNT(*) AS Total_Transactions,
    ROUND(AVG(`Purchase Amount (USD)`), 2) AS Avg_Purchase_Amount,
    SUM(`Purchase Amount (USD)`) AS Total_Revenue
FROM shopping_trends
GROUP BY `Discount Applied`;


---Filtering for "Power Users" who have a high history of purchases and frequent engagement.---
SELECT * FROM shopping_trends
WHERE `Previous Purchases` > 5 
  AND `Frequency of Purchases` IN ('Weekly', 'Bi-Weekly');


---This section builds a loyalty score ($0-100$) using the formula of Min-Max Normalization---
WITH MinMaxBounds AS (
    SELECT 
        `Customer ID`,
        `Previous Purchases`,
        MIN(`Previous Purchases`) OVER() AS Min_Purchases,
        MAX(`Previous Purchases`) OVER() AS Max_Purchases,
        `Review Rating`,
        MIN(`Review Rating`) OVER() AS Min_Rating,
        MAX(`Review Rating`) OVER() AS Max_Rating,
        `Subscription Status`
    FROM shopping_trends
)
SELECT 
    `Customer ID`,
    -- Normalize Previous Purchases
    ROUND(((`Previous Purchases` - Min_Purchases) / NULLIF(Max_Purchases - Min_Purchases, 0)) * 100, 2) AS Norm_Purchases,
    
    -- Normalize Review Ratings
    ROUND(((`Review Rating` - Min_Rating) / NULLIF(Max_Rating - Min_Rating, 0)) * 100, 2) AS Norm_Rating,
    
    -- Normalize Subscription (Boolean)
    CASE WHEN `Subscription Status` = 'Yes' THEN 100 ELSE 0 END AS Norm_Subscription
FROM MinMaxBounds;
